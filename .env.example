# -------------------------------------------------------------------
# TranslateDoc – Local development environment variables
# Copy to .env and fill in your Azure Translator values.
# -------------------------------------------------------------------

# Azure AI Translator – key-based auth (local testing)
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
AZURE_TRANSLATOR_KEY=<your-translator-subscription-key>
AZURE_TRANSLATOR_REGION=eastus

# Set to "true" in Azure (Container App uses Managed Identity)
USE_MANAGED_IDENTITY=false

# Maximum upload size in MB
MAX_FILE_SIZE_MB=10
